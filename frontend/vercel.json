{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://football-stats-lw4b.onrender.com/api/$1"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}