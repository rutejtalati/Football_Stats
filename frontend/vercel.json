{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://footballstats-production-ecd9.up.railway.app/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml" }]
    },
    {
      "source": "/robots.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain" }]
    }
  ]
}